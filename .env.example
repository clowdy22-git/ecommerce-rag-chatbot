# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=800

# --- Weaviate Cloud (free Sandbox) ---
# Sign up at https://console.weaviate.cloud -> create a free "Sandbox" cluster
# (no card needed, ~14 days, easy to recreate). Copy the REST endpoint and
# Admin API key from the cluster's details page. Do NOT wrap values in quotes.
WEAVIATE_CLOUD_URL=your-cluster-id.weaviate.cloud
WEAVIATE_CLOUD_API_KEY=your_weaviate_admin_key_here

# --- App ---
CHUNK_SIZE=300
CHUNK_OVERLAP=50
TOP_K=6
SIMILARITY_THRESHOLD=0.45
